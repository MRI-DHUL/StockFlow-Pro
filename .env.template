# Environment Variables Template
# Copy this file to .env and fill in your actual values
# DO NOT commit .env file to version control!

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
ConnectionStrings__DefaultConnection=Server=your-server;Database=your-db;User Id=user;Password=pass;

# ===========================================
# JWT AUTHENTICATION
# ===========================================
JwtSettings__SecretKey=Your-Super-Secret-JWT-Key-Must-Be-At-Least-32-Characters-Long!
JwtSettings__Issuer=StockFlowProAPI
JwtSettings__Audience=StockFlowProClient
JwtSettings__ExpiryInHours=24

# ===========================================
# REDIS CACHE (Optional)
# ===========================================
# Leave empty to use in-memory cache
ConnectionStrings__Redis=

# ===========================================
# EMAIL CONFIGURATION (Gmail)
# ===========================================
GmailSettings__SmtpServer=smtp.gmail.com
GmailSettings__SmtpPort=587
GmailSettings__SenderEmail=your-email@gmail.com
GmailSettings__SenderName=StockFlow Pro
GmailSettings__SenderPassword=your-gmail-app-password
GmailSettings__AdminEmails__0=admin@example.com

# ===========================================
# PUSHER (Real-time Notifications)
# ===========================================
PusherSettings__AppId=your-pusher-app-id
PusherSettings__Key=your-pusher-key
PusherSettings__Secret=your-pusher-secret
PusherSettings__Cluster=ap2
PusherSettings__DefaultChannel=stockflow-notifications

# ===========================================
# HANGFIRE (Background Jobs)
# ===========================================
HangfireSettings__DashboardTitle=StockFlow Pro - Background Jobs
HangfireSettings__DashboardPath=/hangfire
HangfireSettings__WorkerCount=5

# ===========================================
# CACHE SETTINGS
# ===========================================
CacheSettings__DefaultExpirationMinutes=10
CacheSettings__ProductsCacheMinutes=15
CacheSettings__InventoryCacheMinutes=5

# ===========================================
# GENERAL SETTINGS
# ===========================================
ASPNETCORE_ENVIRONMENT=Production
AllowedHosts=*
