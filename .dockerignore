# .dockerignore at repository root for Railway

# Frontend (not needed for backend deployment)
application/frontend/

# Git
.git/
.github/

# IDE
.vs/
.vscode/
*.user
*.suo

# Deployment files
deploy-azure.ps1
deploy-azure.sh
.env.template
*.md
!application/backend/README.md

# Build outputs (Docker will rebuild these)
**/bin/
**/obj/
**/publish/
**/out/

# Logs
**/Logs/
**/*.log

# Tests (optional - include if needed for integration tests)
application/backend/tests/
